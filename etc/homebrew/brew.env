# For documentation, see: https://docs.brew.sh/Manpage#environment

HOMEBREW_CASK_OPTS='--require-sha'
HOMEBREW_CACHE=/home/linuxbrew/.cache/Homebrew
HOMEBREW_NO_ANALYTICS=1
HOMEBREW_NO_INSECURE_REDIRECT=1
HOMEBREW_REQUIRE_TAP_TRUST=1
HOMEBREW_SYSTEM_ENV_TAKES_PRIORITY=1
HOMEBREW_TEMP=/var/tmp/homebrew

# Make brew bundle only manage Homebrew packages
HOMEBREW_BUNDLE_CLEANUP_NO_CARGO=1
HOMEBREW_BUNDLE_DUMP_NO_CARGO=1
HOMEBREW_BUNDLE_CLEANUP_NO_FLATPAK=1
HOMEBREW_BUNDLE_DUMP_NO_FLATPAK=1
HOMEBREW_BUNDLE_CLEANUP_NO_GO=1
HOMEBREW_BUNDLE_DUMP_NO_GO=1
HOMEBREW_BUNDLE_CLEANUP_NO_KREW=1
HOMEBREW_BUNDLE_DUMP_NO_KREW=1
HOMEBREW_BUNDLE_CLEANUP_NO_MAS=1
HOMEBREW_BUNDLE_DUMP_NO_MAS=1
HOMEBREW_BUNDLE_CLEANUP_NO_NPM=1
HOMEBREW_BUNDLE_DUMP_NO_NPM=1
HOMEBREW_BUNDLE_CLEANUP_NO_UV=1
HOMEBREW_BUNDLE_DUMP_NO_UV=1
HOMEBREW_BUNDLE_CLEANUP_NO_VSCODE=1
HOMEBREW_BUNDLE_DUMP_NO_VSCODE=1
HOMEBREW_BUNDLE_CLEANUP_NO_WINGET=1
HOMEBREW_BUNDLE_DUMP_NO_WINGET=1
